# ─── Sanity ──────────────────────────────────────────────────────────────────
# Dein Sanity Project ID (aus manage.sanity.io)
NEXT_PUBLIC_SANITY_PROJECT_ID=your_project_id

# Dataset (meistens "production")
NEXT_PUBLIC_SANITY_DATASET=production

# Nur im CMS-Studio benötigt, nicht im Read-only-Client
# SANITY_API_TOKEN=your_sanity_api_token

# ─── Airtable ────────────────────────────────────────────────────────────────
# Personal Access Token (aus airtable.com/create/tokens)
AIRTABLE_API_KEY=patXXXXXXXXXXXXXX

# Base ID (beginnt mit "app", aus der URL: airtable.com/appXXX/...)
AIRTABLE_BASE_ID=appFNIVTc3lm4PS7g

# Tabellen-Namen
AIRTABLE_BEWERBUNGEN_TABLE=Bewerbungen

# ─── Brevo ───────────────────────────────────────────────────────────────────
# API Key aus app.brevo.com → API Keys
BREVO_API_KEY=xkeysib-XXXXXXXX

# Template IDs (in Brevo unter Email Templates)
BREVO_CONFIRMATION_TEMPLATE_ID=1
BREVO_NOTIFICATION_TEMPLATE_ID=2

# E-Mail, an die Bewerbungsbenachrichtigungen gehen
BREVO_NOTIFICATION_EMAIL=hallo@boogly.studio

# ─── App ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://boogly.studio
